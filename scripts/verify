#!/usr/bin/env bash
# scripts/verify — local gate for ghx. Run before pushing or releasing.
# Mirrors what CI checks: formatting, vet, race-enabled tests, and a build.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "==> gofmt"
unformatted="$(gofmt -l src/ || true)"
if [ -n "$unformatted" ]; then
  echo "not gofmt-clean:" >&2
  echo "$unformatted" >&2
  exit 1
fi

echo "==> go vet"
go vet ./...

echo "==> go test -race"
go test -race ./...

echo "==> build"
make build >/dev/null

echo "OK — verify passed"
